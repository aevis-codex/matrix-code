# 公开模板只保留本地占位值。真实数据库、中间件地址和密钥请写入不提交 Git 的 .env.local。
MATRIXCODE_PERSISTENCE_MODE=jdbc
SERVER_PORT=8080
MATRIXCODE_MYSQL_HOST=127.0.0.1
MATRIXCODE_MYSQL_PORT=3306
MATRIXCODE_MYSQL_DATABASE=matrix_code
MATRIXCODE_PERSISTENCE_JDBC_URL="jdbc:mysql://127.0.0.1:3306/matrix_code?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8&connectTimeout=5000&socketTimeout=30000"
MATRIXCODE_PERSISTENCE_JDBC_USERNAME=matrixcode_user
MATRIXCODE_PERSISTENCE_JDBC_PASSWORD=change-me
MATRIXCODE_PERSISTENCE_JDBC_MIGRATE_ON_STARTUP=true
MATRIXCODE_PERSISTENCE_JDBC_CREATE_DATABASE_IF_MISSING=true
MATRIXCODE_PERSISTENCE_JDBC_LEGACY_SNAPSHOT_WRITES_ENABLED=false
MATRIXCODE_PRODUCTION_CHECK=false
MATRIXCODE_PROTOCOL_CHECK=false

MATRIXCODE_AUTH_REQUIRE_SIGNED_ACTOR_TOKEN=false
MATRIXCODE_AUTH_REQUIRE_SA_TOKEN=true
MATRIXCODE_AUTH_ACTOR_TOKEN_SECRET=change-me-at-least-32-chars
MATRIXCODE_AUTH_BOOTSTRAP_TOKEN=change-me-bootstrap-token
MATRIXCODE_AUTH_DEFAULT_TOKEN_TTL_SECONDS=86400
MATRIXCODE_AUTH_SESSION_STORE=redis
MATRIXCODE_AUTH_SESSION_REDIS_KEY_PREFIX=matrixcode:sa-token:
MATRIXCODE_AUTH_ADMIN_INITIAL_PASSWORD=change-me-admin-password
SA_TOKEN_TOKEN_NAME=Authorization
SA_TOKEN_TOKEN_PREFIX=Bearer
SA_TOKEN_TIMEOUT=86400
SA_TOKEN_ACTIVE_TIMEOUT=-1
SA_TOKEN_IS_READ_HEADER=true
SA_TOKEN_IS_READ_BODY=false
SA_TOKEN_IS_READ_COOKIE=false
MATRIXCODE_EXECUTION_AGENTS_SHARED_SECRET=change-me-execution-agent-secret
MATRIXCODE_EXECUTION_AGENTS_PREVIOUS_SHARED_SECRETS=
MATRIXCODE_EXECUTION_AGENTS_HEARTBEAT_TTL_SECONDS=120
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_ENABLED=false
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_ID=demo
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_NAME=MatrixCode Demo
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_OWNER_USER_ID=user-owner
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_OWNER_DISPLAY_NAME=项目负责人
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_CURRENT_STAGE=真实库初始化

MATRIXCODE_QWEN_ENABLED=true
MATRIXCODE_QWEN_API_KEY=change-me
MATRIXCODE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

MATRIXCODE_DEEPSEEK_ENABLED=true
MATRIXCODE_DEEPSEEK_API_KEY=change-me
MATRIXCODE_DEEPSEEK_BASE_URL=https://api.deepseek.com

MATRIXCODE_KIMI_ENABLED=true
MATRIXCODE_KIMI_API_KEY=change-me
MATRIXCODE_KIMI_BASE_URL=https://api.moonshot.cn/v1

MATRIXCODE_DOUBAO_ENABLED=true
MATRIXCODE_DOUBAO_API_KEY=change-me
MATRIXCODE_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

MATRIXCODE_PRODUCT_PROVIDER_ID=qwen
MATRIXCODE_PRODUCT_MODEL=qwen-plus
MATRIXCODE_DEVELOPER_PROVIDER_ID=deepseek
MATRIXCODE_DEVELOPER_MODEL=deepseek-chat
MATRIXCODE_TESTER_PROVIDER_ID=deepseek
MATRIXCODE_TESTER_MODEL=deepseek-chat
MATRIXCODE_OPERATIONS_PROVIDER_ID=qwen
MATRIXCODE_OPERATIONS_MODEL=qwen-plus
# 角色可在界面或 /model-binding API 中切换供应商。
# 已验证可切换模型示例：kimi/kimi-k2.5，doubao/doubao-seed-1-6-flash-250615。

MATRIXCODE_MILVUS_HOST=127.0.0.1
MATRIXCODE_MILVUS_PORT=19530
MATRIXCODE_MILVUS_DATABASE=matrix_code
MATRIXCODE_MILVUS_COLLECTION=matrixcode_context_chunks_v2
MATRIXCODE_MILVUS_SECURE=false
MATRIXCODE_MILVUS_USERNAME=
MATRIXCODE_MILVUS_PASSWORD=
MATRIXCODE_MILVUS_TOKEN=
MATRIXCODE_EMBEDDING_PROVIDER_ID=qwen
MATRIXCODE_EMBEDDING_MODEL=text-embedding-v4
MATRIXCODE_VECTOR_CONTEXT_ENABLED=true
MATRIXCODE_VECTOR_CONTEXT_STORE=milvus
MATRIXCODE_VECTOR_CONTEXT_TOP_K=3
MATRIXCODE_VECTOR_CONTEXT_DIMENSION=1024

# Redis 默认用于 Sa-Token 分布式会话；本地离线开发可显式改为 memory。
# RocketMQ 当前仍按业务需要预留。
MATRIXCODE_REDIS_HOST=127.0.0.1
MATRIXCODE_REDIS_PORT=6379
MATRIXCODE_REDIS_PASSWORD=
MATRIXCODE_REDIS_TIMEOUT=5s
MATRIXCODE_ROCKETMQ_NAME_SERVER=127.0.0.1:9876
MATRIXCODE_ROCKETMQ_TOPIC_PREFIX=matrixcode
MATRIXCODE_ROCKETMQ_PROTOCOL_CHECK=false
MATRIXCODE_ROCKETMQ_EVENT_RELAY_ENABLED=false
MATRIXCODE_ROCKETMQ_EVENT_RELAY_TOPIC_SUFFIX=project-events
MATRIXCODE_ROCKETMQ_EVENT_RELAY_TAG=project-event
MATRIXCODE_ROCKETMQ_EVENT_RELAY_PRODUCER_GROUP_SUFFIX=project-event-producer
MATRIXCODE_ROCKETMQ_EVENT_RELAY_CONSUMER_GROUP_SUFFIX=project-event-consumer
MATRIXCODE_ROCKETMQ_EVENT_RELAY_SEND_TIMEOUT_MS=3000
MATRIXCODE_ROCKETMQ_EVENT_RELAY_CONSUME_THREAD_MIN=2
MATRIXCODE_ROCKETMQ_EVENT_RELAY_CONSUME_THREAD_MAX=4
