# 生产公开模板只保留占位值。上线时复制到服务器私有 env 文件后再填真实地址和密钥。
MATRIXCODE_APP_HOME=/opt/matrixcode
MATRIXCODE_ENV_FILE=/etc/matrixcode/matrixcode.env
MATRIXCODE_SERVER_JAR=/opt/matrixcode/matrixcode-server.jar
MATRIXCODE_RUN_PREFLIGHT=true
MATRIXCODE_JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC

SERVER_PORT=8080
MATRIXCODE_PERSISTENCE_MODE=jdbc
MATRIXCODE_MYSQL_HOST=127.0.0.1
MATRIXCODE_MYSQL_PORT=3306
MATRIXCODE_MYSQL_DATABASE=matrix_code
MATRIXCODE_PERSISTENCE_JDBC_URL=jdbc:mysql://127.0.0.1:3306/matrix_code?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8&connectTimeout=5000&socketTimeout=30000
MATRIXCODE_PERSISTENCE_JDBC_USERNAME=replace_with_database_user
MATRIXCODE_PERSISTENCE_JDBC_PASSWORD=replace_with_database_credential
MATRIXCODE_PERSISTENCE_JDBC_MIGRATE_ON_STARTUP=true
MATRIXCODE_PERSISTENCE_JDBC_CREATE_DATABASE_IF_MISSING=true
MATRIXCODE_PERSISTENCE_JDBC_LEGACY_SNAPSHOT_WRITES_ENABLED=false

MATRIXCODE_PRODUCTION_CHECK=true
MATRIXCODE_PROTOCOL_CHECK=true
MATRIXCODE_AUTH_REQUIRE_SA_TOKEN=true
MATRIXCODE_AUTH_SESSION_STORE=redis
MATRIXCODE_AUTH_SESSION_REDIS_KEY_PREFIX=matrixcode:sa-token:
MATRIXCODE_AUTH_ACTOR_TOKEN_SECRET=replace_with_actor_token_credential
MATRIXCODE_AUTH_BOOTSTRAP_TOKEN=replace_with_bootstrap_credential
MATRIXCODE_AUTH_ADMIN_INITIAL_PASSWORD=replace_with_admin_password
MATRIXCODE_EXECUTION_AGENTS_SHARED_SECRET=replace_with_execution_agent_credential
MATRIXCODE_EXECUTION_AGENTS_PREVIOUS_SHARED_SECRETS=
MATRIXCODE_EXECUTION_AGENTS_HEARTBEAT_TTL_SECONDS=120

MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_ENABLED=false
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_ID=demo
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_NAME=MatrixCode Demo
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_OWNER_USER_ID=user-owner
MATRIXCODE_BOOTSTRAP_INITIAL_PROJECT_OWNER_DISPLAY_NAME=项目负责人

MATRIXCODE_QWEN_ENABLED=true
MATRIXCODE_QWEN_API_KEY=replace_with_qwen_credential
MATRIXCODE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MATRIXCODE_DEEPSEEK_ENABLED=true
MATRIXCODE_DEEPSEEK_API_KEY=replace_with_deepseek_credential
MATRIXCODE_DEEPSEEK_BASE_URL=https://api.deepseek.com
MATRIXCODE_KIMI_ENABLED=true
MATRIXCODE_KIMI_API_KEY=replace_with_kimi_credential
MATRIXCODE_KIMI_BASE_URL=https://api.moonshot.cn/v1
MATRIXCODE_DOUBAO_ENABLED=true
MATRIXCODE_DOUBAO_API_KEY=replace_with_doubao_credential
MATRIXCODE_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

MATRIXCODE_PRODUCT_PROVIDER_ID=qwen
MATRIXCODE_PRODUCT_MODEL=qwen-plus
MATRIXCODE_DEVELOPER_PROVIDER_ID=deepseek
MATRIXCODE_DEVELOPER_MODEL=deepseek-chat
MATRIXCODE_TESTER_PROVIDER_ID=deepseek
MATRIXCODE_TESTER_MODEL=deepseek-chat
MATRIXCODE_OPERATIONS_PROVIDER_ID=qwen
MATRIXCODE_OPERATIONS_MODEL=qwen-plus

MATRIXCODE_MILVUS_HOST=127.0.0.1
MATRIXCODE_MILVUS_PORT=19530
MATRIXCODE_MILVUS_DATABASE=matrix_code
MATRIXCODE_MILVUS_COLLECTION=matrixcode_context_chunks_v2
MATRIXCODE_MILVUS_SECURE=false
MATRIXCODE_MILVUS_USERNAME=
MATRIXCODE_MILVUS_PASSWORD=
MATRIXCODE_MILVUS_TOKEN=
MATRIXCODE_EMBEDDING_PROVIDER_ID=qwen
MATRIXCODE_EMBEDDING_MODEL=text-embedding-v4
MATRIXCODE_VECTOR_CONTEXT_ENABLED=true
MATRIXCODE_VECTOR_CONTEXT_STORE=milvus
MATRIXCODE_VECTOR_CONTEXT_TOP_K=3
MATRIXCODE_VECTOR_CONTEXT_DIMENSION=1024

MATRIXCODE_REDIS_HOST=127.0.0.1
MATRIXCODE_REDIS_PORT=6379
MATRIXCODE_REDIS_PASSWORD=
MATRIXCODE_REDIS_TIMEOUT=5s
MATRIXCODE_ROCKETMQ_NAME_SERVER=127.0.0.1:9876
MATRIXCODE_ROCKETMQ_TOPIC_PREFIX=matrixcode
MATRIXCODE_ROCKETMQ_PROTOCOL_CHECK=false
MATRIXCODE_ROCKETMQ_EVENT_RELAY_ENABLED=false
MATRIXCODE_ROCKETMQ_EVENT_RELAY_TOPIC_SUFFIX=project-events
MATRIXCODE_ROCKETMQ_EVENT_RELAY_TAG=project-event
MATRIXCODE_ROCKETMQ_EVENT_RELAY_PRODUCER_GROUP_SUFFIX=project-event-producer
MATRIXCODE_ROCKETMQ_EVENT_RELAY_CONSUMER_GROUP_SUFFIX=project-event-consumer
MATRIXCODE_ROCKETMQ_EVENT_RELAY_SEND_TIMEOUT_MS=3000
MATRIXCODE_ROCKETMQ_EVENT_RELAY_CONSUME_THREAD_MIN=2
MATRIXCODE_ROCKETMQ_EVENT_RELAY_CONSUME_THREAD_MAX=4

MATRIXCODE_HEALTH_PROBE_URL=http://127.0.0.1:8080/actuator/health
MATRIXCODE_INFO_PROBE_URL=http://127.0.0.1:8080/actuator/info
MATRIXCODE_HEALTH_PROBE_TIMEOUT_SECONDS=5
MATRIXCODE_HEALTH_SNAPSHOT_OUTPUT=
MATRIXCODE_ALERT_WEBHOOK_URL=
MATRIXCODE_ALERT_WEBHOOK_SECRET=
MATRIXCODE_ALERT_WEBHOOK_FORMAT=matrixcode
MATRIXCODE_ALERT_WEBHOOK_RETRIES=2
MATRIXCODE_ALERT_WEBHOOK_RETRY_DELAY_SECONDS=1
MATRIXCODE_ALERT_SEVERITY=P1
MATRIXCODE_ALERT_ESCALATION_OWNER=
MATRIXCODE_ALERT_RUNBOOK_URL=
MATRIXCODE_ALERT_SILENCE_UNTIL_EPOCH_SECONDS=0
MATRIXCODE_ALERT_SILENCE_REASON=

MATRIXCODE_BACKUP_DIR=/var/backups/matrixcode/mysql
MATRIXCODE_BACKUP_RETENTION_DAYS=14
MATRIXCODE_BACKUP_OFFSITE_ENABLED=false
MATRIXCODE_BACKUP_OFFSITE_TARGET=
MATRIXCODE_BACKUP_OFFSITE_DRY_RUN=false
MATRIXCODE_BACKUP_OFFSITE_CONFIRM=false

MATRIXCODE_REMOTE_RELEASE_TARGET=
MATRIXCODE_REMOTE_RELEASE_DIR=/tmp/matrixcode-releases
MATRIXCODE_REMOTE_RELEASE_PREFLIGHT_CONNECT=false
MATRIXCODE_REMOTE_RELEASE_PREFLIGHT_TIMEOUT_SECONDS=5
MATRIXCODE_REMOTE_RELEASE_DRY_RUN=false
MATRIXCODE_REMOTE_RELEASE_CONFIRM=false
MATRIXCODE_REMOTE_APP_DIR=/opt/matrixcode
MATRIXCODE_REMOTE_SYSTEMD_SERVICE=matrixcode
MATRIXCODE_REMOTE_HEALTH_PROBE_URL=http://127.0.0.1:8080/actuator/health
MATRIXCODE_REMOTE_INFO_PROBE_URL=http://127.0.0.1:8080/actuator/info
MATRIXCODE_REMOTE_ENV_FILE=/etc/matrixcode/matrixcode.env
MATRIXCODE_REMOTE_HEALTH_SNAPSHOT_DIR=/var/log/matrixcode/health-snapshots
MATRIXCODE_REMOTE_RELOAD_NGINX=false
MATRIXCODE_REMOTE_NGINX_SERVICE=nginx
MATRIXCODE_DEPLOY_DRY_RUN=false
MATRIXCODE_DEPLOY_CONFIRM=false
MATRIXCODE_DEPLOY_CAPTURE_HEALTH_SNAPSHOT=true
MATRIXCODE_DEPLOY_SMOKE_ENV_FILE=

MATRIXCODE_SYSTEMD_SERVICE=matrixcode
MATRIXCODE_RELOAD_NGINX=false
MATRIXCODE_NGINX_SERVICE=nginx
MATRIXCODE_RESTART_DRY_RUN=false
MATRIXCODE_RESTART_CONFIRM=false

MATRIXCODE_ROLLBACK_DRY_RUN=false
MATRIXCODE_ROLLBACK_CONFIRM=false
MATRIXCODE_ROLLBACK_AUDIT_LOG=/var/log/matrixcode/rollback-audit.jsonl
