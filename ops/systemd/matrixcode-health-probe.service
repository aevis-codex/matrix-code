[Unit]
Description=MatrixCode production health probe
Wants=network-online.target
After=network-online.target matrixcode.service

[Service]
Type=oneshot
User=matrixcode
Group=matrixcode
WorkingDirectory=/opt/matrixcode
EnvironmentFile=/etc/matrixcode/matrixcode.env
Environment=MATRIXCODE_ENV_FILE=/etc/matrixcode/matrixcode.env
ExecStart=/opt/matrixcode/scripts/probe-production-health.sh /etc/matrixcode/matrixcode.env
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/log/matrixcode
